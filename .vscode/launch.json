{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Handwriter",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/handwriter/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Pre-Launch Setup",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}